<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysPolicyBindMapper">
    
    <resultMap type="SysPolicyBind" id="SysPolicyBindResult">
        <result property="id"    column="id"    />
        <result property="policyId"    column="policy_id"    />
        <result property="bindType"    column="bind_type"    />
        <result property="bindTargetId"    column="bind_target_id"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectSysPolicyBindVo">
        select id, policy_id, bind_type, bind_target_id, status, remark, create_by, create_time from sys_policy_bind
    </sql>

    <select id="selectSysPolicyBindList" parameterType="SysPolicyBind" resultMap="SysPolicyBindResult">
        <include refid="selectSysPolicyBindVo"/>
        <where>  
            <if test="policyId != null "> and policy_id = #{policyId}</if>
            <if test="bindType != null  and bindType != ''"> and bind_type = #{bindType}</if>
            <if test="bindTargetId != null "> and bind_target_id = #{bindTargetId}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>
    
    <select id="selectSysPolicyBindById" parameterType="Long" resultMap="SysPolicyBindResult">
        <include refid="selectSysPolicyBindVo"/>
        where id = #{id}
    </select>

    <insert id="insertSysPolicyBind" parameterType="SysPolicyBind" useGeneratedKeys="true" keyProperty="id">
        insert into sys_policy_bind
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="policyId != null">policy_id,</if>
            <if test="bindType != null and bindType != ''">bind_type,</if>
            <if test="bindTargetId != null">bind_target_id,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="policyId != null">#{policyId},</if>
            <if test="bindType != null and bindType != ''">#{bindType},</if>
            <if test="bindTargetId != null">#{bindTargetId},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
         </trim>
    </insert>

    <update id="updateSysPolicyBind" parameterType="SysPolicyBind">
        update sys_policy_bind
        <trim prefix="SET" suffixOverrides=",">
            <if test="policyId != null">policy_id = #{policyId},</if>
            <if test="bindType != null and bindType != ''">bind_type = #{bindType},</if>
            <if test="bindTargetId != null">bind_target_id = #{bindTargetId},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSysPolicyBindById" parameterType="Long">
        delete from sys_policy_bind where id = #{id}
    </delete>

    <delete id="deleteSysPolicyBindByIds" parameterType="String">
        delete from sys_policy_bind where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>