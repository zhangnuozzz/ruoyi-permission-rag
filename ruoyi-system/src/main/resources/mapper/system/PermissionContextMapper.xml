<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.system.mapper.PermissionContextMapper">

    <resultMap id="GroupInfoResult" type="com.ruoyi.system.domain.permission.GroupInfo">
        <result property="groupId" column="group_id"/>
        <result property="groupCode" column="group_code"/>
        <result property="groupName" column="group_name"/>
        <result property="scopeCode" column="scope_code"/>
        <result property="status" column="status"/>
    </resultMap>

    <resultMap id="PolicyInfoResult" type="com.ruoyi.system.domain.permission.PolicyInfo">
        <result property="policyId" column="policy_id"/>
        <result property="policyCode" column="policy_code"/>
        <result property="policyName" column="policy_name"/>
        <result property="effect" column="effect"/>
        <result property="subjectType" column="subject_type"/>
        <result property="subjectExpr" column="subject_expr"/>
        <result property="resourceExpr" column="resource_expr"/>
        <result property="envExpr" column="env_expr"/>
        <result property="priority" column="priority"/>
        <result property="status" column="status"/>
    </resultMap>

    <select id="selectGroupsByUserId" parameterType="Long" resultMap="GroupInfoResult">
        SELECT
            g.id AS group_id,
            g.group_code,
            g.group_name,
            g.scope_code,
            g.status
        FROM sys_user_group_rel r
        INNER JOIN sys_group g ON r.group_id = g.id
        WHERE r.user_id = #{userId}
          AND g.status = '0'
          AND g.del_flag = '0'
        ORDER BY g.id ASC
    </select>

    <select id="selectPoliciesByUserId" parameterType="Long" resultMap="PolicyInfoResult">
        SELECT DISTINCT
            p.id AS policy_id,
            p.policy_code,
            p.policy_name,
            p.effect,
            p.subject_type,
            p.subject_expr,
            p.resource_expr,
            p.env_expr,
            p.priority,
            p.status
        FROM sys_policy p
        INNER JOIN sys_policy_bind b ON p.id = b.policy_id
        LEFT JOIN sys_user_group_rel r
            ON b.bind_type = 'GROUP'
           AND b.bind_target_id = r.group_id
           AND r.user_id = #{userId}
        WHERE p.status = '0'
          AND p.del_flag = '0'
          AND b.status = '0'
          AND (
                (b.bind_type = 'USER' AND b.bind_target_id = #{userId})
                OR
                (b.bind_type = 'GROUP' AND r.user_id IS NOT NULL)
              )
        ORDER BY p.priority ASC, p.id ASC
    </select>

</mapper>
