<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.system.mapper.SysAccessLogMapper">

    <resultMap type="SysAccessLog" id="SysAccessLogResult">
        <id     property="accessId"      column="access_id" />
        <result property="userId"        column="user_id" />
        <result property="userName"      column="user_name" />
        <result property="ipaddr"        column="ipaddr" />
        <result property="requestUri"    column="request_uri" />
        <result property="requestMethod" column="request_method" />
        <result property="status"        column="status" />
        <result property="errorMsg"      column="error_msg" />
        <result property="costTime"      column="cost_time" />
        <result property="createTime"    column="create_time" />
    </resultMap>

    <sql id="selectSysAccessLogVo">
        select access_id, user_id, user_name, ipaddr, request_uri, request_method,
               status, error_msg, cost_time, create_time
        from sys_access_log
    </sql>

    <select id="selectSysAccessLogList" parameterType="SysAccessLog" resultMap="SysAccessLogResult">
        <include refid="selectSysAccessLogVo"/>
        <where>
            <if test="userId != null"> and user_id = #{userId}</if>
            <if test="userName != null and userName != ''"> and user_name like concat('%', #{userName}, '%')</if>
            <if test="ipaddr != null and ipaddr != ''"> and ipaddr like concat('%', #{ipaddr}, '%')</if>
            <if test="requestUri != null and requestUri != ''"> and request_uri like concat('%', #{requestUri}, '%')</if>
            <if test="requestMethod != null and requestMethod != ''"> and request_method = #{requestMethod}</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
            <if test="params.beginCreateTime != null and params.beginCreateTime != ''">
                and date_format(create_time, '%Y%m%d') &gt;= date_format(#{params.beginCreateTime}, '%Y%m%d')
            </if>
            <if test="params.endCreateTime != null and params.endCreateTime != ''">
                and date_format(create_time, '%Y%m%d') &lt;= date_format(#{params.endCreateTime}, '%Y%m%d')
            </if>
        </where>
        order by access_id desc
    </select>

    <select id="selectSysAccessLogById" parameterType="Long" resultMap="SysAccessLogResult">
        <include refid="selectSysAccessLogVo"/>
        where access_id = #{accessId}
    </select>

    <insert id="insertSysAccessLog" parameterType="SysAccessLog" useGeneratedKeys="true" keyProperty="accessId">
        insert into sys_access_log
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="userName != null">user_name,</if>
            <if test="ipaddr != null">ipaddr,</if>
            <if test="requestUri != null">request_uri,</if>
            <if test="requestMethod != null">request_method,</if>
            <if test="status != null">status,</if>
            <if test="errorMsg != null">error_msg,</if>
            <if test="costTime != null">cost_time,</if>
            create_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="userName != null">#{userName},</if>
            <if test="ipaddr != null">#{ipaddr},</if>
            <if test="requestUri != null">#{requestUri},</if>
            <if test="requestMethod != null">#{requestMethod},</if>
            <if test="status != null">#{status},</if>
            <if test="errorMsg != null">#{errorMsg},</if>
            <if test="costTime != null">#{costTime},</if>
            sysdate()
        </trim>
    </insert>

    <delete id="deleteSysAccessLogById" parameterType="Long">
        delete from sys_access_log where access_id = #{accessId}
    </delete>

    <delete id="deleteSysAccessLogByIds" parameterType="Long">
        delete from sys_access_log where access_id in
        <foreach item="accessId" collection="array" open="(" separator="," close=")">
            #{accessId}
        </foreach>
    </delete>

    <delete id="cleanSysAccessLog">
        truncate table sys_access_log
    </delete>

</mapper>
