<template>
  <div class="app-container">
    <el-card shadow="never">
      <div slot="header">
        <span>RAG 安全检索测试</span>
      </div>

      <el-form :model="form" label-width="100px">
        <el-form-item label="检索问题">
          <el-input
            v-model="form.query"
            type="textarea"
            :rows="4"
            placeholder="请输入要检索的问题，例如：测试从文档权限标签表读取候选结果"
          />
        </el-form-item>

        <el-form-item>
          <el-button type="primary" :loading="loading" @click="handleSearch">
            开始检索
          </el-button>
          <el-button @click="reset">
            重置
          </el-button>
        </el-form-item>
      </el-form>
    </el-card>

    <el-card v-if="result" shadow="never" style="margin-top: 20px;">
      <div slot="header">
        <span>权限决策结果</span>
      </div>

      <el-descriptions :column="2" border>
        <el-descriptions-item label="用户ID">
          {{ result.userId }}
        </el-descriptions-item>
        <el-descriptions-item label="用户名">
          {{ result.userName }}
        </el-descriptions-item>
        <el-descriptions-item label="是否管理员">
          {{ result.admin }}
        </el-descriptions-item>
        <el-descriptions-item label="是否放行">
          <el-tag :type="result.allowAccess ? 'success' : 'danger'">
            {{ result.allowAccess ? '放行' : '拒绝' }}
          </el-tag>
        </el-descriptions-item>
        <el-descriptions-item label="用户组">
          {{ formatArray(result.groupCodes) }}
        </el-descriptions-item>
        <el-descriptions-item label="知悉范围">
          {{ formatArray(result.scopeCodes) }}
        </el-descriptions-item>
        <el-descriptions-item label="metadataFilter" :span="2">
          <el-tag type="info">
            {{ result.metadataFilter }}
          </el-tag>
        </el-descriptions-item>
        <el-descriptions-item label="候选结果数">
          {{ result.rawResultCount }}
        </el-descriptions-item>
        <el-descriptions-item label="过滤后结果数">
          {{ result.filteredResultCount }}
        </el-descriptions-item>
        <el-descriptions-item label="耗时">
          {{ result.costTime }} ms
        </el-descriptions-item>
        <el-descriptions-item label="决策说明">
          {{ result.decisionMessage }}
        </el-descriptions-item>
      </el-descriptions>
    </el-card>

    <el-card v-if="result" shadow="never" style="margin-top: 20px;">
      <div slot="header">
        <span>过滤后文档结果</span>
      </div>

      <el-table :data="result.filteredResults" border>
        <el-table-column label="文档ID" prop="docId" width="120" />
        <el-table-column label="标题" prop="title" width="180" />
        <el-table-column label="知悉范围" prop="scopeCode" width="120">
          <template slot-scope="scope">
            <el-tag>{{ scope.row.scopeCode }}</el-tag>
          </template>
        </el-table-column>
        <el-table-column label="密级" prop="level" width="120" />
        <el-table-column label="过滤状态" prop="passed" width="120">
          <template slot-scope="scope">
            <el-tag :type="scope.row.passed ? 'success' : 'danger'">
              {{ scope.row.passed ? '通过' : '拒绝' }}
            </el-tag>
          </template>
        </el-table-column>
        <el-table-column label="过滤说明" prop="filterReason" width="240" />
        <el-table-column label="内容" prop="content" min-width="300" show-overflow-tooltip />
      </el-table>
    </el-card>
  </div>
</template>

<script>
import { ragSearch } from '@/api/rag/search'

export default {
  name: 'RagSearch',
  data() {
    return {
      loading: false,
      form: {
        query: '测试从文档权限标签表读取候选结果'
      },
      result: null
    }
  },
  methods: {
    handleSearch() {
      if (!this.form.query) {
        this.$modal.msgWarning('请输入检索问题')
        return
      }

      this.loading = true
      ragSearch(this.form).then(response => {
        this.result = response.data
        this.$modal.msgSuccess('检索完成')
      }).finally(() => {
        this.loading = false
      })
    },
    reset() {
      this.form.query = ''
      this.result = null
    },
    formatArray(value) {
      if (!value || value.length === 0) {
        return '-'
      }
      return value.join(', ')
    }
  }
}
</script>
